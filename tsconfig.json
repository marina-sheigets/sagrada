{
	"compilerOptions": {
		"outDir": "./dist/",
		"rootDir": "./src",
		"noImplicitAny": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"target": "esnext",
		"jsx": "react-jsx",
		"allowJs": true,
		// for tsyringe
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules"]
}
